# MongoDB 配置
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_DB_NAME=apt_entity_db
MONGO_USERNAME=
MONGO_PASSWORD=

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Sentence-BERT 模型配置
BERT_MODEL_PATH=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# 算法阈值配置
LEVENSHTEIN_THRESHOLD=0.8
SEMANTIC_THRESHOLD=0.75

# 缓存配置（秒）
CACHE_VECTOR_TTL=604800
CACHE_QUERY_TTL=3600

